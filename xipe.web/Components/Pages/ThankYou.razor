@page "/thankyou"

<PageTitle>Thank You – Xipe</PageTitle>

<section id="thankyou">
    <div class="contact-bg" style="background-image: url('https://images.unsplash.com/photo-1454789548928-9efd52dc4031?w=1920&auto=format&fit=crop&q=80');"></div>
    <div class="contact-overlay"></div>
    <div class="thankyou-inner">
        <div class="thankyou-icon">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <span class="section-label">Message Received</span>
        <h1 class="thankyou-title">Thank you for<br />contacting us.</h1>
        <p class="thankyou-subtitle">
            We've received your message and will get back to you as soon as possible.<br />
            In the meantime, feel free to explore our services.
        </p>
        <div class="thankyou-actions">
            <a href="/" class="btn-hero">Back to Home &rarr;</a>
            <a href="/software-development" class="btn-outline">Explore Services &rarr;</a>
        </div>
    </div>
</section>
