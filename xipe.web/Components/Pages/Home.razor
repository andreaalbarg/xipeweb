<!-- CONTACT -->
<section id="contact">
    <div class="contact-bg" style="background-image: url('https://images.unsplash.com/photo-1454789548928-9efd52dc4031?w=1920&auto=format&fit=crop&q=80');"></div>
    <div class="contact-overlay"></div>
    <div class="contact-inner">
        <span class="section-label">Get in Touch</span>
        <h2 class="contact-title">Let's build something great.</h2>
        <p class="contact-subtitle">Tell us about your project and we'll get back to you within 24 hours.</p>

        @if (formSent)
        {
            <div class="form-success">
                <p>Thanks, @formName! We'll get back to you within 24 hours.</p>
            </div>
        }
        else
        {
            <form class="contact-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }
                <div class="form-row">
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input type="text" id="name" placeholder="Your name" @bind="formName" required />
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" placeholder="you@company.com" @bind="formEmail" required />
                    </div>
                </div>
                <div class="form-group">
                    <label for="company">Company</label>
                    <input type="text" id="company" placeholder="Your company" @bind="formCompany" />
                </div>
                <div class="form-group">
                    <label for="service">What are you looking for?</label>
                    <select id="service" @bind="formService">
                        <option value="" disabled selected>Select a service</option>
                        <option value="Product Development">Product Development</option>
                        <option value="AI &amp; Technology Consulting">AI &amp; Technology Consulting</option>
                        <option value="Staff Augmentation">Staff Augmentation</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" placeholder="Tell us about your project..." @bind="formMessage"></textarea>
                </div>
                <button type="submit" class="btn-contact" disabled="@isSending">
                    @(isSending ? "Sending..." : "Send Message →")
                </button>
            </form>
        }
    </div>
</section>

@code {
    string formName = "";
    string formEmail = "";
    string formCompany = "";
    string formService = "";
    string formMessage = "";
    bool isSending = false;
    bool formSent = false;
    string formError = "";

    async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(formName) || string.IsNullOrWhiteSpace(formEmail))
            return;

        isSending = true;
        formError = "";

        try
        {
            await EmailService.SendContactFormAsync(formName, formEmail, formCompany, formService, formMessage);
            formSent = true;
        }
        catch (Exception ex)
        {
            formError = "Something went wrong. Please try again or email us directly at hola@xipetechnology.com.";
            _ = ex;
        }
        finally
        {
            isSending = false;
        }
    }
}
